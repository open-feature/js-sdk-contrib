{
  "name": "flagd-core",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/flagd-core/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run publish-if-not-exists",
        "cwd": "dist/libs/shared/flagd-core"
      },
      "dependsOn": ["build"]
    },
    "pullTestHarness": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["git submodule update --init spec", "git submodule update --init test-harness"],
        "cwd": "libs/shared/flagd-core",
        "parallel": false
      }
    },
    "buildValidators": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["git submodule update --init flagd-schemas", "node scripts/build-validators.js"],
        "cwd": "libs/shared/flagd-core",
        "parallel": false
      },
      "dependsOn": ["pullTestHarness"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "dependsOn": ["buildValidators"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "dependsOn": ["buildValidators", "test-edge"],
      "options": {
        "jestConfig": "libs/shared/flagd-core/jest.config.ts"
      }
    },
    "test-edge": {
      "executor": "@nx/jest:jest",
      "dependsOn": ["buildValidators"],
      "options": {
        "jestConfig": "libs/shared/flagd-core/jest.edge.config.ts"
      }
    },
    "package": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "dependsOn": ["pullTestHarness", "buildValidators"],
      "options": {
        "project": "libs/shared/flagd-core/package.json",
        "outputPath": "dist/libs/shared/flagd-core",
        "entryFile": "libs/shared/flagd-core/src/index.ts",
        "tsConfig": "libs/shared/flagd-core/tsconfig.lib.json",
        "compiler": "tsc",
        "generateExportsField": true,
        "umdName": "flagd-core",
        "external": "all",
        "format": ["cjs", "esm"],
        "assets": [
          {
            "glob": "package.json",
            "input": "./assets",
            "output": "./src/"
          },
          {
            "glob": "LICENSE",
            "input": "./",
            "output": "./"
          },
          {
            "glob": "README.md",
            "input": "./libs/shared/flagd-core",
            "output": "./"
          }
        ]
      }
    }
  }
}
